<?xml version="1.0" encoding="utf-8"?>
<RuleSet Name="CatLib Code Analysis Ruleset" Description="The catlib code analysis ruleset" ToolsVersion="10.0">
  <Include Path="analysis.ruleset" Action="Default" />
  <Rules AnalyzerId="Microsoft.CodeQuality.Analyzers" RuleNamespace="Microsoft.CodeQuality.Analyzers">
	<Rule Id="CA2000" Action="None" /> <!-- Call IDisposable.Dispose -->
  </Rules>
  <Rules AnalyzerId="StyleCop.Analyzers" RuleNamespace="StyleCop.Analyzers">
	<Rule Id="SA1600" Action="None" /> <!-- Elements must be documented -->
  </Rules>
  <Rules AnalyzerId="SonarAnalyzer.CSharp" RuleNamespace="SonarAnalyzer.CSharp">
	<Rule Id="S1121" Action="None" /> <!-- Assignments should not be made from within sub-expressions -->
	<Rule Id="S2699" Action="None" /> <!-- Tests should include assertions -->
	<Rule Id="S2187" Action="None" /> <!-- Add some tests in the file -->
	<!-- Test-style rules new in SonarAnalyzer 10. The existing MSTest style
	     (ExpectedException, AreEqual with bool literals, empty fixture classes)
	     is valid idiomatic MSTest and rewriting it buys us nothing. -->
	<Rule Id="S2094" Action="None" /> <!-- Remove empty class (test fixtures for abstract types) -->
	<Rule Id="S2701" Action="None" /> <!-- Literal boolean passed as argument to Assert.AreEqual -->
	<Rule Id="S3431" Action="None" /> <!-- Replace ExpectedException with throw assertion / try-catch -->
	<Rule Id="S3993" Action="None" /> <!-- Specify AttributeUsage explicitly even when inherited -->
  </Rules>
</RuleSet>